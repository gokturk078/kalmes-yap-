# Public Supabase connection (required for website and admin login)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Admin restrictions in UI
NEXT_PUBLIC_ADMIN_EMAIL=kalmesyapi@gmail.com

# Bucket name used for project photos
NEXT_PUBLIC_SUPABASE_PROJECTS_BUCKET=project-images

# Server-side only: required for seed script
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Contact form is stored in Supabase (public.contact_messages)
# No SMTP / Resend required
